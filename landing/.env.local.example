# Copy to landing/.env.local and fill in. Never commit .env.local.
#
# Vite only exposes env vars prefixed with VITE_ to the browser, so these
# keys are safe-to-publish (the anon key is gated by Row Level Security).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...
