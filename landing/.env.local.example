# Copy to landing/.env.local and fill in. Never commit .env.local.
#
# Vite only exposes env vars prefixed with VITE_ to the browser, so these
# keys are safe-to-publish (the anon key is gated by Row Level Security).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# API base URL (Hono server). If unset, local dev defaults to http://localhost:8787
# (or same hostname as this page on port 8787 for LAN testing).
#
# Vercel / production: REQUIRED — set to your deployed API origin, HTTPS, no trailing slash:
#   VITE_API_URL=https://your-api.fly.dev
VITE_API_URL=http://localhost:8787
