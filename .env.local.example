# Copy to .env.local and fill in. Never commit .env.local.
#
# Server-side / agent secrets only. Browser-exposed keys (VITE_SUPABASE_URL,
# VITE_SUPABASE_ANON_KEY) live in landing/.env.local instead — see that file.

# ── Supabase (auth + Postgres) ────────────────────────────────────────
# Service role key is used by trusted server processes (agents, scripts)
# that need to bypass RLS. Never expose to the browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Sonnet 4.5 — vision + reasoning + intervention) ────────
ANTHROPIC_API_KEY=

# ── Mathpix (handwriting → LaTeX OCR) ─────────────────────────────────
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ── ElevenLabs (Flash v2.5 streaming TTS) ─────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=             # pick warm + conversational, not narrator-y

# ── Backboard (longitudinal struggle memory — the brain) ──────────────
BACKBOARD_API_KEY=
BACKBOARD_BASE_URL=https://app.backboard.io/api
