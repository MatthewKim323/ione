# Copy to .env.local and fill in. Never commit .env.local.

# ── Auth0 ─────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=                    # openssl rand -hex 32
APP_BASE_URL=http://localhost:3000

# ── Auth0 Fine-Grained Authorization (parent/teacher dashboards) ──────
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=
FGA_CLIENT_ID=
FGA_CLIENT_SECRET=

# ── Anthropic (Sonnet 4.5 — vision + reasoning + intervention) ────────
ANTHROPIC_API_KEY=

# ── Mathpix (handwriting → LaTeX OCR) ─────────────────────────────────
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ── ElevenLabs (Flash v2.5 streaming TTS) ─────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=             # pick warm + conversational, not narrator-y

# ── Backboard (longitudinal struggle memory — the brain) ──────────────
BACKBOARD_API_KEY=
BACKBOARD_BASE_URL=https://app.backboard.io/api

# ── Database (user → Backboard assistant_id mapping) ──────────────────
DATABASE_URL=postgres://user:pass@host:5432/margin

# ── Storage (audio hint MP3s) ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=
