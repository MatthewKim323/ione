{
  "name": "ione-api",
  "version": "0.1.0",
  "private": true,
  "description": "Margin tutor API — Hono on Node. Orchestrates OCR / Reasoning / Predictive / Intervention agents over SSE.",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "RUN_EVAL=1 vitest run tests/orchestrator.test.ts tests/kg"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.13.0",
    "@supabase/supabase-js": "^2.104.1",
    "dotenv": "^16.4.7",
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.0.0"
  }
}
